# ===== Environment Configuration =====
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ===== Gateway Configuration =====
GATEWAY_PORT=8000
GATEWAY_HOST=0.0.0.0
GATEWAY_WORKERS=4

# LINE Configuration
LINE_CHANNEL_ID=your_line_channel_id_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_ACCESS_TOKEN=your_line_access_token_here

# ===== Router Configuration =====
ROUTER_PORT=8001
ROUTER_HOST=0.0.0.0

# ===== Database Configuration =====
# PostgreSQL
DB_DRIVER=postgresql
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=rip_dev
DB_URL=postgresql://postgres:password@postgres:5432/rip_dev

# Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ===== Redis Configuration =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ===== Message Queue Configuration =====
TASK_QUEUE_BACKEND=redis  # or celery
QUEUE_NAME=rip_tasks
QUEUE_PRIORITY_LEVELS=5

# ===== AI Model API Keys =====

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_TIMEOUT=120
ANTHROPIC_MAX_RETRIES=3

# OpenAI GPT
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=3

# Google Gemini
GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_TIMEOUT=120
GOOGLE_MAX_RETRIES=3

# ===== Integration API Keys =====

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_BASE_URL=https://api.github.com
GITHUB_TIMEOUT=60

# AWS
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=rip-platform-bucket
AWS_TIMEOUT=60

# Google Calendar
GOOGLE_CALENDAR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Taipei

# ===== Security Configuration =====
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-chars-here

# ===== Feature Flags =====
ENABLE_RAG=false
ENABLE_MCP=false
ENABLE_AGENT=false
ENABLE_TASK_QUEUE=false
ENABLE_MONITORING=true
ENABLE_DEBUG_ENDPOINTS=true

# ===== Worker Configuration =====
WORKER_TIMEOUT=120
WORKER_MAX_RETRIES=3
WORKER_HEARTBEAT_INTERVAL=30
WORKER_REGISTRY_URL=http://rip-worker-registry:8002

# Worker Specific
ENABLE_CLAUDE_WORKER=true
ENABLE_GPT_WORKER=true
ENABLE_GEMINI_WORKER=true
ENABLE_PDF_WORKER=true
ENABLE_FOLDER_WORKER=true
ENABLE_GITHUB_WORKER=true
ENABLE_AWS_WORKER=true
ENABLE_CALENDAR_WORKER=true

# ===== AI Router Configuration =====
ROUTER_INTENT_CONFIDENCE_THRESHOLD=0.7
ROUTER_MAX_WORKFLOW_DEPTH=10
ROUTER_TASK_TIMEOUT=300
ROUTER_CONFIRMATION_TIMEOUT=300

# Worker Selection Strategy
WORKER_SELECTION_STRATEGY=hybrid
WORKER_QUALITY_WEIGHT=0.4
WORKER_COST_WEIGHT=0.3
WORKER_PERFORMANCE_WEIGHT=0.2
WORKER_AVAILABILITY_WEIGHT=0.1

# ===== Monitoring & Logging =====
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15

SENTRY_DSN=
SENTRY_ENABLED=false

# Logging
LOG_FORMAT=json
LOG_OUTPUT=console,file
LOG_FILE_PATH=./logs/app.log
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=5

# ===== Performance & Resource Limits =====
MAX_CONCURRENT_REQUESTS=100
MAX_CONCURRENT_WORKERS=10
REQUEST_TIMEOUT=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# Cost Management
COST_LIMIT_ENABLED=true
COST_LIMIT_MONTHLY_USD=1000  # Monthly budget
COST_WARNING_THRESHOLD_USD=800  # Alert threshold

# ===== Storage Configuration =====
DATA_STORAGE_PATH=./data
PDF_STORAGE_PATH=./data/pdf
REPO_STORAGE_PATH=./data/repos
BACKUP_PATH=./backups

# File Upload Limits
MAX_UPLOAD_FILE_SIZE=104857600  # 100 MB
MAX_TOTAL_STORAGE_SIZE=1099511627776  # 1 TB

# ===== Deployment Configuration =====
DEPLOYMENT_ENVIRONMENT=development  # development, staging, production
DEPLOYMENT_REGION=local
DEPLOYMENT_VERSION=0.1.0

# ===== Slack/Notification (Optional) =====
SLACK_WEBHOOK_URL=
SLACK_ENABLED=false

# ===== Email Configuration (Optional) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_ENABLED=false

# ===== Development Only =====
# Uncomment these for local development
# MOCK_EXTERNAL_APIS=true
# USE_LOCAL_EMBEDDINGS=true
# SKIP_API_KEY_VALIDATION=false
